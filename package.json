{
  "name": "time-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "prepare": "node git-version-gen.js",
    "prebuild": "node git-version-gen.js",
    "postbuild": "gzipper compress --gzip-level=9 --include js,json,css,html ./dist",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "npm run lint && npm run format && npm test && npm run e2e && npm run build",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:vrt": "VRT=1 playwright test",
    "e2e:vrt:baseline": "VRT=1 playwright test --update-snapshots",
    "e2e:vrt:report": "playwright show-report",
    "e2e:vrt:docker": "./scripts/vrt-docker.sh",
    "e2e:vrt:baseline:docker": "./scripts/vrt-docker.sh baseline"
  },
  "dependencies": {
    "@angular-architects/ngrx-toolkit": "^21.0.1",
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/material": "^21.2.5",
    "@angular/material-moment-adapter": "^21.2.5",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@angular/service-worker": "^21.2.7",
    "@fontsource/material-icons": "^4.5.4",
    "@fontsource/roboto": "^5.2.6",
    "@ng-matero/extensions": "^21.1.4",
    "@ng-matero/extensions-moment-adapter": "^21.0.0",
    "@ngrx/signals": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "chart.js": "^4.4.7",
    "events": "^3.3.0",
    "firebase": "^12.0.0",
    "moment": "^2.29.4",
    "ng2-charts": "^8.0.0",
    "pouchdb-browser": "^8.0.1",
    "pouchdb-find": "^8.0.1",
    "rxjs": "^7.5.7",
    "tslib": "^2.6.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@ngrx/schematics": "^21.1.0",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.12.0",
    "@types/pouchdb-browser": "^6.1.3",
    "@types/ws": "^8.5.4",
    "git-rev-sync": "^3.0.2",
    "gzipper": "^7.2.0",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  }
}
